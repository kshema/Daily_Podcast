OPENAI_API_KEY=sk-your-openai-key
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.5

ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
TTS_PROVIDER=elevenlabs
# For free local macOS audio, use:
# TTS_PROVIDER=macos
# AUDIO_OUTPUT_FILE=podcast.m4a
# Optional: MACOS_TTS_VOICE=Samantha and MACOS_TTS_RATE=175
AUDIO_OUTPUT_FILE=podcast.mp3
ENABLE_AUDIO=false

GMAIL_CREDENTIALS_FILE=secrets/google_oauth_client.json
GMAIL_TOKEN_FILE=secrets/token.json
EMAIL_FROM=me
EMAIL_TO=your.address@gmail.com
# Set this true to send the formatted digest email with summary.html and summary.md attached.
ENABLE_EMAIL=false

PODCAST_TIMEZONE=America/New_York
PODCAST_SEND_HOUR=5
PODCAST_SEND_MINUTE=0
PODCAST_OUTPUT_DIR=output
